{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "Content-Type": "application/javascript; charset=utf-8"
      },
      "dest": "/"
    }
  ],
  "github": {
    "silent": true
  }
}